rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      let adminDoc = get(/databases/$(database)/documents/admin_users/$(request.auth.uid));
      return isSignedIn() &&
        adminDoc != null &&
        adminDoc.data.isApproved == true;
    }

    function isSuperAdmin() {
      let adminDoc = get(/databases/$(database)/documents/admin_users/$(request.auth.uid));
      return isSignedIn() &&
        adminDoc != null &&
        adminDoc.data.isApproved == true &&
        adminDoc.data.role == 'super_admin';
    }

    function isBoutiqueOwnerOf(boutiqueId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/boutique_owners/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/boutique_owners/$(request.auth.uid)).data.boutiqueId == boutiqueId &&
        get(/databases/$(database)/documents/boutique_owners/$(request.auth.uid)).data.isApproved == true;
    }

    function isGuestPath(userId) {
      return userId.matches('guest_[0-9a-f]+');
    }

    function isValidUserProfile() {
      let d = request.resource.data;
      return d.firstName is string && d.firstName.size() <= 50 &&
             d.lastName  is string && d.lastName.size()  <= 50 &&
             d.phone     is string && d.phone.size()     <= 20 &&
             d.email     is string && d.email.size()     <= 100;
    }

    function isValidAddress() {
      let d = request.resource.data;
      return d.firstName    is string && d.firstName.size()    <= 50 &&
             d.lastName     is string && d.lastName.size()     <= 50 &&
             d.phone        is string && d.phone.size()        <= 20 &&
             d.governorate  is string && d.governorate.size()  <= 100 &&
             d.area         is string && d.area.size()         <= 100 &&
             d.block        is string && d.block.size()        <= 20 &&
             d.street       is string && d.street.size()       <= 100 &&
             d.house        is string && d.house.size()        <= 20;
    }

    function isValidProduct() {
      let d = request.resource.data;
      return d.title       is string && d.title.size()       <= 100 &&
             d.description is string && d.description.size() <= 2000 &&
             d.price       is number && d.price > 0 && d.price <= 100000 &&
             d.stock       is int    && d.stock              >= 0 &&
             (!('isOutOfStock' in d) || d.isOutOfStock is bool) &&
             (!('salePrice' in d) || d.salePrice == null ||
               (d.salePrice is number && d.salePrice > 0 &&
                d.salePrice < d.price));
    }

    function isValidDiscountCode() {
      let d = request.resource.data;
      return d.code        is string && d.code.size() >= 1 && d.code.size() <= 40 &&
             d.type in ['percentage', 'flat'] &&
             d.value       is number && d.value > 0 &&
             (d.type != 'percentage' || d.value <= 100) &&
             d.isActive    is bool &&
             d.usageCount  is int && d.usageCount >= 0 &&
             (d.usageLimit == null || (d.usageLimit is int && d.usageLimit > 0)) &&
             // Boutique-owned codes carry a boutiqueId (the create rule binds it
             // to the owner's own boutique). Platform-wide codes created by
             // admins may omit it.
             (!('boutiqueId' in d) || d.boutiqueId is string);
    }

    // Shape guard for guest cart writes — only the fields the app actually
    // writes, each bounded. Present-only checks so partial updates (e.g. just
    // quantity) still pass. Closes the unauthenticated free-storage vector.
    function isValidCartItem() {
      let d = request.resource.data;
      return d.keys().hasOnly([
               'productId', 'boutiqueId', 'imageUrl', 'title', 'description',
               'size', 'color', 'price', 'quantity', 'madeToOrder',
               'createdAt', 'updatedAt'
             ]) &&
             (!('productId'   in d) || (d.productId   is string && d.productId.size()   <= 200)) &&
             (!('boutiqueId'  in d) || (d.boutiqueId  is string && d.boutiqueId.size()  <= 200)) &&
             (!('quantity'    in d) || (d.quantity    is int    && d.quantity >= 1 && d.quantity <= 99)) &&
             (!('price'       in d) || (d.price       is number && d.price >= 0 && d.price <= 100000)) &&
             (!('title'       in d) || (d.title       is string && d.title.size()       <= 300)) &&
             (!('imageUrl'    in d) || (d.imageUrl    is string && d.imageUrl.size()    <= 1000)) &&
             (!('description' in d) || (d.description is string && d.description.size() <= 3000)) &&
             (!('size'        in d) || (d.size        is string && d.size.size()        <= 50)) &&
             (!('color'       in d) || (d.color       is string && d.color.size()       <= 50)) &&
             (!('madeToOrder' in d) || d.madeToOrder is bool);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) &&
        request.resource.data.role == 'user' &&
        isValidUserProfile();
      allow update: if (isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role'])) || isAdmin();
      allow delete: if isSuperAdmin();

      match /saved_items/{itemId} {
        allow read, write: if isOwner(userId);
      }
      match /saved_boutiques/{boutiqueId} {
        allow read, write: if isOwner(userId);
      }
      match /following/{boutiqueId} {
        allow read: if isOwner(userId);
        allow create, delete: if isOwner(userId);
        allow update: if false;
      }
      match /saved_addresses/{addressId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidAddress();
      }
      match /cart_items/{itemId} {
        allow read, delete: if isOwner(userId) || isGuestPath(userId);
        // Guest cart writes are shape-validated (the guest path is
        // unauthenticated). Owner writes keep their existing latitude so the
        // post-login guest→user cart merge is unaffected.
        allow create, update: if isOwner(userId) ||
          (isGuestPath(userId) && isValidCartItem());
      }
      match /orders/{orderId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if false;
        allow update: if isAdmin();
        allow delete: if false;
      }
      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        allow update: if isOwner(userId) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['isRead', 'readAt']);
        allow create, delete: if false;
      }
    }

    match /boutiques/{boutiqueId} {
      allow read: if true;
      allow create: if isSuperAdmin();
      allow update: if (isBoutiqueOwnerOf(boutiqueId) || isAdmin()) &&
        // Server-only promo/ranking fields — only Cloud Functions (admin SDK
        // bypasses rules) may write these. Blocked for every client, including
        // admins, so paid promo placement & trending rank can't be set by hand.
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny([
            'followerCount', 'isFeedSponsored', 'feedSponsoredUntil',
            'weeklyOrders', 'salesCount', 'isTrending',
            'totalSales', 'rating', 'reviewCount',
          ]);
      allow delete: if isSuperAdmin();

      match /products/{productId} {
        allow read: if true;
        allow create: if (isBoutiqueOwnerOf(boutiqueId) || isAdmin()) &&
          isValidProduct() &&
          !request.resource.data.keys().hasAny([
            'isFeedSponsored', 'feedSponsoredUntil', 'weeklyOrders',
            'salesCount', 'isTrending', 'totalSales', 'rating', 'reviewCount',
          ]);
        allow update: if (isBoutiqueOwnerOf(boutiqueId) || isAdmin()) &&
          isValidProduct() &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'isFeedSponsored', 'feedSponsoredUntil', 'weeklyOrders',
            'salesCount', 'isTrending', 'totalSales', 'rating', 'reviewCount',
          ]);
        allow delete: if isBoutiqueOwnerOf(boutiqueId) || isAdmin();
      }
      match /orders/{orderId} {
        allow read: if isBoutiqueOwnerOf(boutiqueId) || isAdmin();
        allow create: if false;
        allow update: if isBoutiqueOwnerOf(boutiqueId) || isAdmin();
        allow delete: if false;
      }
    }

    match /boutique_owners/{ownerId} {
      allow read: if isOwner(ownerId) || isAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    match /admin_users/{adminId} {
      allow read: if isOwner(adminId) || isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    match /global_orders/{orderId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.customerUid == request.auth.uid);
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /discount_codes/{codeId} {
      // Owners read their own codes (query filters by boutiqueId); admins read all.
      allow read: if isBoutiqueOwnerOf(resource.data.boutiqueId) || isAdmin();
      allow create: if (isBoutiqueOwnerOf(request.resource.data.boutiqueId) || isAdmin()) &&
        isValidDiscountCode();
      // usageCount is incremented only by Cloud Functions (admin SDK bypasses
      // rules); clients may toggle isActive etc. but never tamper with the
      // redemption counter.
      allow update: if (isBoutiqueOwnerOf(resource.data.boutiqueId) || isAdmin()) &&
        isValidDiscountCode() &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['usageCount']);
      allow delete: if isBoutiqueOwnerOf(resource.data.boutiqueId) || isAdmin();
    }

    match /promo_slot_payments/{paymentId} {
      // Admin-only analytics read. Written exclusively by Cloud Functions via
      // the admin SDK (which bypasses rules), so all client writes are denied.
      allow read: if isAdmin();
      allow write: if false;
    }

    match /payment_intents/{paymentIntentId} {
      // Replay locks for Stripe intents are written only by Cloud Functions.
      allow read: if isAdmin();
      allow write: if false;
    }

    match /disputes/{disputeId} {
      allow read: if isSignedIn() &&
        (resource.data.customerUid == request.auth.uid || isAdmin());
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /metadata/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /manual_notifications/{notifId} {
      allow read, create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /hero_banners/{bannerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /pending_invites/{inviteId} {
      allow read, write: if isSuperAdmin();
    }

    match /rate_limits/{docId} {
      allow read, write: if false; // server-only
    }

    match /{path=**}/products/{productId} {
      allow read: if true;
    }

    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }

  
}
