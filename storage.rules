rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        firestore.exists(/databases/(default)/documents/admin_users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/admin_users/$(request.auth.uid)).data.isApproved == true;
    }

    function isBoutiqueOwner() {
      return isSignedIn() &&
        firestore.exists(/databases/(default)/documents/boutique_owners/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/boutique_owners/$(request.auth.uid)).data.isApproved == true;
    }

    function canWriteOwnerImages(userId) {
      return isSignedIn() &&
        request.auth.uid == userId &&
        (isBoutiqueOwner() || isAdmin());
    }

    match /product_images/{userId}/{fileName} {
      allow read: if true;
      allow write: if canWriteOwnerImages(userId);
    }

    match /product_images/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /boutique_logos/{userId}/{fileName} {
      allow read: if true;
      allow write: if canWriteOwnerImages(userId);
    }

    match /boutique_banners/{userId}/{fileName} {
      allow read: if true;
      allow write: if canWriteOwnerImages(userId);
    }

    match /boutique_images/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /hero_banners/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }

  }
}